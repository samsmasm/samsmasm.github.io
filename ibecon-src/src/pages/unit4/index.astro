---
import Layout from '../../layouts/Layout.astro';

const topics = [
  { num: '4.1', title: 'Benefits of International Trade', desc: 'Comparative advantage, gains from trade, absolute advantage (HL).', hl: false },
  { num: '4.2', title: 'Types of Trade Protection', desc: 'Tariffs, quotas, subsidies, administrative barriers, and their effects on markets.', hl: false },
  { num: '4.3', title: 'Arguments for and Against Protection', desc: 'Infant industries, national security, anti-dumping, ELDC diversification, and disadvantages of protection.', hl: false },
  { num: '4.4', title: 'Economic Integration', desc: 'Trading blocs, WTO, monetary union. Advantages and disadvantages.', hl: false },
  { num: '4.5', title: 'Exchange Rates', desc: 'Floating, fixed, managed exchange rates. Determinants, consequences, and fixed vs floating comparison (HL).', hl: false },
  { num: '4.6', title: 'Balance of Payments', desc: 'Current, capital, and financial accounts. Persistent deficits/surpluses, Marshall-Lerner condition and J-curve (HL).', hl: false },
  { num: '4.7', title: 'Sustainable Development', desc: 'Sustainable development goals, the meaning of sustainability, and relationship to poverty (HL).', hl: false },
  { num: '4.8', title: 'Measuring Development', desc: 'Single and composite development indicators — HDI, GII, IHDI, Happy Planet Index.', hl: false },
  { num: '4.9', title: 'Barriers to Economic Development', desc: 'Poverty traps, economic barriers, and political and social barriers.', hl: false },
  { num: '4.10', title: 'Development Strategies', desc: 'Trade strategies, diversification, social enterprise, market-based and interventionist policies, aid, FDI, and institutional change.', hl: false },
];
---
<Layout title="IBEcon: Unit 4 — The Global Economy">
  <div class="breadcrumb">
    <a href="/ibecon/">Home</a>
    <span class="sep">›</span>
    <span>Unit 4</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 4</span>
    <h1>The Global Economy</h1>
    <p class="subtitle">International trade, exchange rates, balance of payments, sustainable development, and economic development strategies.</p>
  </div>

  <div class="to-come-banner">
    <div class="to-come-label">To come</div>
    <p>Unit 4 resources are currently in development. Pages will be added once teacher resources are available. All topics below are shown for reference only.</p>
  </div>

  <div class="topic-grid" style="margin-top:2rem;">
    {topics.map(t => (
      <div class="topic-card coming-soon">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        <span class="card-coming">To come</span>
      </div>
    ))}
  </div>
</Layout>
