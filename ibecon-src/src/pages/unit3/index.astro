---
import Layout from '../../layouts/Layout.astro';

const topics = [
  { num: '3.1', title: 'Measuring Economic Activity', slug: '3-1', desc: 'GDP, GNI, real vs nominal, per capita, the business cycle, and alternative measures of well-being.', hl: false },
  { num: '3.2', title: 'Aggregate Demand and Supply', slug: '3-2', desc: 'AD curve, components of AD, SRAS and LRAS, Keynesian AS, macroeconomic equilibrium.', hl: false },
  { num: '3.3', title: 'Macroeconomic Objectives', slug: '3-3', desc: 'Economic growth, unemployment, inflation, deflation, government debt, and trade-offs between objectives.', hl: false },
  { num: '3.4', title: 'Economics of Inequality and Poverty', slug: '3-4', desc: 'Lorenz curve, Gini coefficient, poverty, causes of inequality, taxation, and redistribution policies.', hl: false },
  { num: '3.5', title: 'Monetary Policy', slug: '3-5', desc: 'Central bank tools, interest rates, money creation, expansionary and contractionary monetary policy.', hl: false },
  { num: '3.6', title: 'Fiscal Policy', slug: '3-6', desc: 'Government revenue and expenditure, Keynesian multiplier (HL), effectiveness and constraints.', hl: false },
  { num: '3.7', title: 'Supply-side Policies', slug: '3-7', desc: 'Market-based and interventionist supply-side policies — goals, tools, and effectiveness.', hl: false },
];
---
<Layout title="IBEcon: Unit 3 — Macroeconomics">
  <div class="breadcrumb">
    <a href="/ibecon/">Home</a>
    <span class="sep">›</span>
    <span>Unit 3</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 3</span>
    <h1>Macroeconomics</h1>
    <p class="subtitle">
      Select a topic to view class notes, key terms, worked examples and practice questions.
    </p>
  </div>

  <div class="topic-grid">
    {topics.map(t => (
      <a href={`/ibecon/unit3/${t.slug}/`} class="topic-card">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        {t.hl && <span class="card-hl">HL only</span>}
      </a>
    ))}
  </div>
</Layout>
