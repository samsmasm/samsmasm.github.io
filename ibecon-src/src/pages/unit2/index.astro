---
import Layout from '../../layouts/Layout.astro';

const topics = [
  { num: '2.1', title: 'Demand', slug: '2-1', desc: 'Law of demand, demand curve, non-price determinants, movements vs shifts.', hl: false },
  { num: '2.2', title: 'Supply', slug: '2-2', desc: 'Law of supply, supply curve, non-price determinants, movements vs shifts.', hl: false },
  { num: '2.3', title: 'Competitive Market Equilibrium', slug: '2-3', desc: 'Market equilibrium, price mechanism, consumer and producer surplus, allocative efficiency.', hl: false },
  { num: '2.4', title: 'Critique of Maximising Behaviour', slug: '2-4', desc: 'Behavioural economics, biases, bounded rationality, nudge theory, alternative business objectives.', hl: true },
  { num: '2.5', title: 'Elasticities of Demand', slug: '2-5', desc: 'PED, YED — definitions, calculations, determinants, and significance for firms and government.', hl: false },
  { num: '2.6', title: 'Elasticity of Supply', slug: '2-6', desc: 'PES — definition, calculation, determinants, and significance.', hl: false },
  { num: '2.7', title: 'Role of Government in Microeconomics', slug: '2-7', desc: 'Price controls, indirect taxes, subsidies, regulation, and consequences for stakeholders.', hl: false },
  { num: '2.8', title: 'Externalities and Common Pool Resources', slug: '2-8', desc: 'Positive and negative externalities, merit/demerit goods, common pool resources, government responses.', hl: false },
  { num: '2.9', title: 'Market Failure — Public Goods', slug: '2-9', desc: 'Non-rival, non-excludable goods and the free rider problem. Government provision.', hl: false },
  { num: '2.10', title: 'Asymmetric Information', slug: '2-10', desc: 'Adverse selection, moral hazard, and government and private responses.', hl: true },
  { num: '2.11', title: 'Market Power', slug: '2-11', desc: 'Perfect competition, monopoly, oligopoly, monopolistic competition, and profit maximisation.', hl: true },
  { num: '2.12', title: "The Market's Inability to Achieve Equity", slug: '2-12', desc: 'Why free markets produce unequal distributions of income and wealth.', hl: true },
];
---
<Layout title="IBEcon: Unit 2 — Microeconomics">
  <div class="breadcrumb">
    <a href="/ibecon/">Home</a>
    <span class="sep">›</span>
    <span>Unit 2</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 2</span>
    <h1>Microeconomics</h1>
    <p class="subtitle">
      Select a topic to view class notes, key terms, worked examples and practice questions.
    </p>
  </div>

  <div class="topic-grid">
    {topics.map(t => (
      <a href={`/ibecon/unit2/${t.slug}/`} class="topic-card">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        {t.hl && <span class="card-hl">HL only</span>}
      </a>
    ))}
  </div>
</Layout>
