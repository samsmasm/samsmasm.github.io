---
import Layout from '../../layouts/Layout.astro';

const topics = [
  {
    num: '1.1',
    title: 'What is Economics?',
    slug: '1-1',
    desc: 'Economics as a social science, scarcity, choice, opportunity cost, factors of production, economic systems, PPC, and circular flow.',
    hl: false,
  },
  {
    num: '1.2',
    title: 'How Economists Approach the World',
    slug: '1-2',
    desc: 'Positive and normative economics, economic methodology, and the history of economic thought from Adam Smith to behavioural economics.',
    hl: false,
  },
];
---
<Layout title="IBEcon: Unit 1 — Introduction to Economics">
  <div class="breadcrumb">
    <a href="/ibecon/">Home</a>
    <span class="sep">›</span>
    <span>Unit 1</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 1</span>
    <h1>Introduction to Economics</h1>
    <p class="subtitle">
      Select a topic to view class notes, key terms, and practice questions.
    </p>
  </div>

  <div class="topic-grid">
    {topics.map(t => (
      <a href={`/ibecon/unit1/${t.slug}/`} class="topic-card">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        {t.hl && <span class="card-hl">HL only</span>}
      </a>
    ))}
  </div>
</Layout>
