---
const path = Astro.url.pathname;
const active = (prefix: string) =>
  prefix === '/ibecon/'
    ? path === '/ibecon/' || path === '/ibecon'
    : path.startsWith(prefix);
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/ibecon/" class="nav-logo">I Beat<span>Econ</span></a>
    <ul class="nav-links">
      <li><a href="/ibecon/" class:list={[{ active: active('/ibecon/') }]}>Home</a></li>

      <li class="nav-dropdown">
        <a href="/ibecon/unit1/" class:list={[{ active: active('/ibecon/unit1') }]}>Unit 1: Intro</a>
        <ul class="nav-dropdown-menu">
          <li><a href="/ibecon/unit1/1-1/">1.1 What is Economics?</a></li>
          <li><a href="/ibecon/unit1/1-2/">1.2 How Economists Approach the World</a></li>
        </ul>
      </li>

      <li class="nav-dropdown">
        <a href="/ibecon/unit2/" class:list={[{ active: active('/ibecon/unit2') }]}>Unit 2: Micro</a>
        <ul class="nav-dropdown-menu">
          <li><a href="/ibecon/unit2/2-1/">2.1 Demand</a></li>
          <li><a href="/ibecon/unit2/2-2/">2.2 Supply</a></li>
          <li><a href="/ibecon/unit2/2-3/">2.3 Competitive Market Equilibrium</a></li>
          <li><a href="/ibecon/unit2/2-4/">2.4 Critique of Maximising Behaviour <span class="hl-badge">HL</span></a></li>
          <li><a href="/ibecon/unit2/2-5/">2.5 Elasticities of Demand</a></li>
          <li><a href="/ibecon/unit2/2-6/">2.6 Elasticity of Supply</a></li>
          <li><a href="/ibecon/unit2/2-7/">2.7 Role of Government</a></li>
          <li><a href="/ibecon/unit2/2-8/">2.8 Externalities &amp; Common Pool Resources</a></li>
          <li><a href="/ibecon/unit2/2-9/">2.9 Public Goods</a></li>
          <li><a href="/ibecon/unit2/2-10/">2.10 Asymmetric Information <span class="hl-badge">HL</span></a></li>
          <li><a href="/ibecon/unit2/2-11/">2.11 Market Power <span class="hl-badge">HL</span></a></li>
          <li><a href="/ibecon/unit2/2-12/">2.12 Equity &amp; the Market <span class="hl-badge">HL</span></a></li>
        </ul>
      </li>

      <li class="nav-dropdown">
        <a href="/ibecon/unit3/" class:list={[{ active: active('/ibecon/unit3') }]}>Unit 3: Macro</a>
        <ul class="nav-dropdown-menu">
          <li><a href="/ibecon/unit3/3-1/">3.1 Measuring Economic Activity</a></li>
          <li><a href="/ibecon/unit3/3-2/">3.2 Aggregate Demand &amp; Supply</a></li>
          <li><a href="/ibecon/unit3/3-3/">3.3 Macroeconomic Objectives</a></li>
          <li><a href="/ibecon/unit3/3-4/">3.4 Inequality &amp; Poverty</a></li>
          <li><a href="/ibecon/unit3/3-5/">3.5 Monetary Policy</a></li>
          <li><a href="/ibecon/unit3/3-6/">3.6 Fiscal Policy</a></li>
          <li><a href="/ibecon/unit3/3-7/">3.7 Supply-side Policies</a></li>
        </ul>
      </li>

      <li class="nav-dropdown">
        <a href="/ibecon/unit4/" class:list={[{ active: active('/ibecon/unit4') }]}>Unit 4: Global</a>
        <ul class="nav-dropdown-menu">
          <li style="padding: 0.5rem 1rem; color: rgba(255,255,255,0.45); font-size: 0.82rem; font-style: italic;">To come — resources in development</li>
        </ul>
      </li>
    </ul>
  </div>
</nav>
