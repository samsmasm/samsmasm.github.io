rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the current user an admin?
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_admin == true;
    }

    // Users can read/write their own profile
    match /users/{uid} {
      allow read: if request.auth.uid == uid;
      allow create: if request.auth.uid == uid;
      // Only allow updating safe fields (not is_admin — set that manually or via admin SDK)
      allow update: if request.auth.uid == uid &&
        !('is_admin' in request.resource.data.diff(resource.data).affectedKeys());
    }

    // User's progress and personal cards — fully owned by that user
    match /users/{uid}/progress/{doc} {
      allow read, write: if request.auth.uid == uid;
    }

    match /users/{uid}/cards/{doc} {
      allow read, write: if request.auth.uid == uid;
    }

    // Decks: anyone authenticated can read; only admins can write
    match /decks/{deckId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /words/{wordId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
      }
    }
  }
}
