---
const path = Astro.url.pathname;
const active = (prefix: string) =>
  prefix === '/ibbm/'
    ? path === '/ibbm/' || path === '/finhub'
    : path.startsWith(prefix);
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/ibbm/" class="nav-logo">I Beat<span>BM</span></a>
    <ul class="nav-links">
      <li><a href="/ibbm/" class:list={[{ active: active('/ibbm/') }]}>Home</a></li>
      <li><a href="/ibbm/unit1/" class:list={[{ active: active('/ibbm/unit1') }]}>Unit 1: Intro</a></li>
      <li><a href="/ibbm/unit3/" class:list={[{ active: active('/ibbm/unit3') }]}>Unit 3: Finance</a></li>
      <li><a href="/ratibro/" class="nav-ratibro">Practice at Ratibro</a></li>
    </ul>
  </div>
</nav>
