---
import Layout from '../layouts/Layout.astro';
---
<Layout title="I Beat Business Management">
  <div style="padding: 2rem 0 1rem;">
    <h1>I Beat<br /><span style="color: var(--blue);">Business Management</span></h1>
    <p style="margin-top: 0.75rem; font-size: 1.05rem; color: var(--text-muted); max-width: 520px; line-height: 1.7;">
      Class notes, key terms, worked examples and exercises — topic by topic.
    </p>
  </div>

  <div class="section">
    <h2 style="margin-top: 1.5rem;">Units</h2>
    <div class="topic-grid">
      <a href="/ibbm/unit1/" class="topic-card">
        <div class="card-num">Unit 1</div>
        <div class="card-title">Introduction to Business Management</div>
        <div class="card-desc">
          What is a business, types of entities, objectives, stakeholders,
          growth and evolution, and multinational companies.
        </div>
      </a>
      <a href="/ibbm/unit3/" class="topic-card">
        <div class="card-num">Unit 3</div>
        <div class="card-title">Finance &amp; Accounts</div>
        <div class="card-desc">
          Sources of finance, final accounts, ratio analysis, cash flow,
          investment appraisal, and budgets (HL).
        </div>
      </a>
      <a href="/ibbm/casestudies/" class="topic-card">
        <div class="card-num">Cases</div>
        <div class="card-title">Case Studies</div>
        <div class="card-desc">
          Extended scenarios for analysis and evaluation: Ignite Apparel, FairStart Microfinance, and Should They Grow?
        </div>
      </a>
    </div>
  </div>
</Layout>
