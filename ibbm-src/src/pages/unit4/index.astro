---
import Layout from '../../layouts/Layout.astro';

const topics = [
  { num: '4.1', title: 'Introduction to Marketing', slug: '4-1', desc: 'What marketing is, market share, market growth, product and market orientation.', hl: false },
  { num: '4.2', title: 'Marketing Planning', slug: '4-2', desc: 'Segmentation, targeting, positioning, niche vs mass markets, USP, and differentiation.', hl: false },
  { num: '4.3', title: 'Sales Forecasting', slug: '4-3', desc: 'Extrapolation, time series analysis, simple linear regression, and forecasting limitations.', hl: true },
  { num: '4.4', title: 'Market Research', slug: '4-4', desc: 'Primary and secondary research, qualitative vs quantitative, sampling methods, and ethics.', hl: false },
  { num: '4.5a', title: 'Product', slug: '4-5-product', desc: 'Product life cycle, extension strategies, BCG matrix, branding, and packaging.', hl: false },
  { num: '4.5b', title: 'Price', slug: '4-5-price', desc: 'Pricing strategies, price elasticity of demand, and how price fits the marketing mix.', hl: false },
  { num: '4.5c', title: 'Promotion', slug: '4-5-promotion', desc: 'ATL, BTL, TTL, social media marketing, and promotional objectives.', hl: false },
  { num: '4.5d', title: 'Place', slug: '4-5-place', desc: 'Distribution channels — zero-level, one-level, two-level, and factors affecting channel choice.', hl: false },
  { num: '4.5e', title: 'People', slug: '4-5-people', desc: 'Employee–customer relationships, cultural variation, and managing service staff.', hl: false },
  { num: '4.5f', title: 'Processes', slug: '4-5-processes', desc: 'How service delivery works, and why the process is part of the product.', hl: false },
  { num: '4.5g', title: 'Physical Evidence', slug: '4-5-physical', desc: 'The tangible cues that signal service quality before the service is experienced.', hl: false },
  { num: '4.6', title: 'International Marketing', slug: '4-6', desc: 'Opportunities and threats of international markets, entry methods, standardisation vs adaptation.', hl: true },
];
---
<Layout title="IBBM: Unit 4 — Marketing">
  <div class="breadcrumb">
    <a href="/ibbm/">Home</a>
    <span class="sep">›</span>
    <span>Unit 4</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 4</span>
    <h1>Marketing</h1>
    <p class="subtitle">
      Select a topic to view notes, worked examples, and practice exercises.
      <strong>HL only</strong> content is clearly labelled throughout.
    </p>
  </div>

  <div class="topic-grid">
    {topics.map(t => (
      <a href={`/ibbm/unit4/${t.slug}/`} class="topic-card">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        {t.hl && <span class="card-hl">HL only</span>}
      </a>
    ))}
  </div>
</Layout>
