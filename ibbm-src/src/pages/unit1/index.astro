---
import Layout from '../../layouts/Layout.astro';

const topics = [
  {
    num: '1.1',
    title: 'What is a Business?',
    slug: '1-1',
    desc: 'The nature of business, economic sectors, entrepreneurship, and challenges of starting up.',
    hl: false,
  },
  {
    num: '1.2',
    title: 'Types of Business Entities',
    slug: '1-2',
    desc: 'Public vs private sector, sole traders, partnerships, companies, social enterprises, and NGOs.',
    hl: false,
  },
  {
    num: '1.3',
    title: 'Business Objectives',
    slug: '1-3',
    desc: 'Vision and mission statements, business objectives, strategic vs tactical objectives, and CSR.',
    hl: false,
  },
  {
    num: '1.4',
    title: 'Stakeholders',
    slug: '1-4',
    desc: 'Internal and external stakeholders, stakeholder interests, and sources of conflict.',
    hl: false,
  },
  {
    num: '1.5',
    title: 'Growth and Evolution',
    slug: '1-5',
    desc: 'Internal vs external growth, economies of scale, and external growth methods (M&As, franchising…).',
    hl: false,
  },
  {
    num: '1.6',
    title: 'Multinational Companies',
    slug: '1-6',
    desc: 'The impact of MNCs on host countries — benefits and drawbacks.',
    hl: false,
  },
];
---
<Layout title="IBBM: Unit 1 — Introduction to Business Management">
  <div class="breadcrumb">
    <a href="/ibbm/">Home</a>
    <span class="sep">›</span>
    <span>Unit 1</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 1</span>
    <h1>Introduction to Business Management</h1>
    <p class="subtitle">
      Select a topic to view class notes, key terms, worked examples and exercises.
    </p>
  </div>

  <div class="topic-grid">
    {topics.map(t => (
      <a href={`/ibbm/unit1/${t.slug}/`} class="topic-card">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        {t.hl && <span class="card-hl">HL only</span>}
      </a>
    ))}
  </div>
</Layout>
