---
import Layout from '../../layouts/Layout.astro';

const topics = [
  {
    num: '3.1',
    title: 'Introduction to Finance',
    slug: '3-1',
    desc: 'The role of finance for businesses. Capital vs. revenue expenditure.',
    hl: false,
  },
  {
    num: '3.2',
    title: 'Sources of Finance',
    slug: '3-2',
    desc: 'Internal sources (retained profit, asset sales) and external sources (shares, loans, crowdfunding…). Short vs. long term.',
    hl: false,
  },
  {
    num: '3.3',
    title: 'Costs and Revenues',
    slug: '3-3',
    desc: 'Fixed, variable, direct and indirect costs. Total revenue and revenue streams.',
    hl: false,
  },
  {
    num: '3.4',
    title: 'Final Accounts',
    slug: '3-4',
    desc: 'Profit & loss account, balance sheet, intangible assets. Depreciation methods (HL).',
    hl: false,
  },
  {
    num: '3.5',
    title: 'Profitability & Liquidity Ratios',
    slug: '3-5',
    desc: 'Gross profit margin, profit margin, ROCE. Current ratio and acid test ratio.',
    hl: false,
  },
  {
    num: '3.6',
    title: 'Efficiency Ratio Analysis',
    slug: '3-6',
    desc: 'Stock turnover, debtor days, creditor days, gearing ratio. Insolvency vs. bankruptcy.',
    hl: true,
  },
  {
    num: '3.7',
    title: 'Cash Flow',
    slug: '3-7',
    desc: 'Profit vs. cash flow, working capital, liquidity position, cash flow forecasts.',
    hl: false,
  },
  {
    num: '3.8',
    title: 'Investment Appraisal',
    slug: '3-8',
    desc: 'Payback period, average rate of return (ARR), and net present value / NPV (HL).',
    hl: false,
  },
  {
    num: '3.9',
    title: 'Budgets',
    slug: '3-9',
    desc: 'Cost and profit centres. Constructing budgets. Variances and decision-making.',
    hl: true,
  },
  {
    num: '5.5',
    title: 'Break-Even Analysis',
    slug: '5-5',
    desc: 'Contribution, break-even output, margin of safety, target profit, and break-even charts.',
    hl: false,
  },
];
---
<Layout title="Unit 3: Finance & Accounts">
  <div class="breadcrumb">
    <a href="/finhub/">Home</a>
    <span class="sep">›</span>
    <span>Unit 3</span>
  </div>

  <div class="topic-hero">
    <span class="topic-number">Unit 3</span>
    <h1>Finance &amp; Accounts</h1>
    <p class="subtitle">
      Select a topic to view class notes, key terms, worked examples and exercises.
      <strong>HL only</strong> content is clearly labelled throughout.
    </p>
  </div>

  <div class="topic-grid">
    {topics.map(t => (
      <a href={`/finhub/unit3/${t.slug}/`} class="topic-card">
        <div class="card-num">{t.num}</div>
        <div class="card-title">{t.title}</div>
        <div class="card-desc">{t.desc}</div>
        {t.hl && <span class="card-hl">HL only</span>}
      </a>
    ))}
  </div>
</Layout>
