---
const path = Astro.url.pathname;
const active = (prefix: string) =>
  prefix === '/finhub/'
    ? path === '/finhub/' || path === '/finhub'
    : path.startsWith(prefix);
---
<nav class="nav">
  <div class="nav-inner">
    <a href="/finhub/" class="nav-logo">Finance<span>Hub</span></a>
    <ul class="nav-links">
      <li><a href="/finhub/" class:list={[{ active: active('/finhub/') }]}>Home</a></li>
      <li><a href="/finhub/unit3/" class:list={[{ active: active('/finhub/unit3') }]}>Unit 3: Finance</a></li>
    </ul>
  </div>
</nav>
